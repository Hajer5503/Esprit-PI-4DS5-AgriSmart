        "# These add no predictive signal — the model would just learn a constant\n",
        "LOW_VAR_THRESHOLD = 30  # kg/ha std\n",
        "\n",
        "low_var_crops = crop_std[crop_std < LOW_VAR_THRESHOLD].index.tolist()\n",
        "\n",
        "if low_var_crops:\n",
        "    print(f\"Removing {len(low_var_crops)} low-variance crops:\")\n",
        "    for c in low_var_crops:\n",
        "        print(f\"  - {c}\")\n",
        "    df = df[~df[\"crop\"].isin(low_var_crops)].reset_index(drop=True)\n",
        "else:\n",
        "    print(\"No crops removed — all have sufficient variance ✅\")\n",
        "\n",
        "print(f\"\\nRemaining crops: {df['crop'].nunique()}\")\n",
        "print(f\"Remaining rows : {len(df)}\")"
