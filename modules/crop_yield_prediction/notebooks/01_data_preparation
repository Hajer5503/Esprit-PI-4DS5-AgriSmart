        "# ── Keep only what we need ────────────────────────────────────────────────\n",
        "df = df_raw[[\"Item\", \"Year\", \"Value\", \"Flag Description\"]].copy()\n",
        "\n",
        "df = df.rename(columns={\n",
        "    \"Item\"             : \"crop\",\n",
        "    \"Year\"             : \"year\",\n",
        "    \"Value\"            : \"yield_kg_ha\",\n",
        "    \"Flag Description\" : \"data_quality\"\n",
        "})\n",
        "\n",
        "df[\"year\"]       = df[\"year\"].astype(int)\n",
        "df[\"yield_kg_ha\"] = pd.to_numeric(df[\"yield_kg_ha\"], errors=\"coerce\")\n",
        "\n",
        "print(f\"Clean shape : {df.shape}\")\n",
        "print(f\"Year range  : {df['year'].min()} – {df['year'].max()}\")\n",
        "print(f\"Crops       : {df['crop'].nunique()}\")\n",
        "print(f\"\\nData quality flags:\")\n",
        "print(df[\"data_quality\"].value_counts().to_string())"
