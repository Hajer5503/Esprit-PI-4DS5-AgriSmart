      "source": [
        "# ── Encode categorical variables ──────────────────────────────────────────\n",
        "from sklearn.preprocessing import LabelEncoder\n",
        "\n",
        "le_crop  = LabelEncoder()\n",
        "le_group = LabelEncoder()\n",
        "\n",
        "df_merged[\"crop_encoded\"]  = le_crop.fit_transform(df_merged[\"crop\"])\n",
        "df_merged[\"group_encoded\"] = le_group.fit_transform(df_merged[\"crop_group\"])\n",
        "\n",
        "# Save label encoders mapping for reference (important for later modeling)\n",
        "import json\n",
        "\n",
        "crop_mapping  = {int(v): k for k, v in zip(le_crop.classes_,\n",
        "                 le_crop.transform(le_crop.classes_))}\n",
        "group_mapping = {int(v): k for k, v in zip(le_group.classes_,\n",
        "                 le_group.transform(le_group.classes_))}\n",
        "\n",
        "with open(\"crop_label_encodings.json\", \"w\") as f:\n",
        "    json.dump({\"crop\": crop_mapping, \"group\": group_mapping}, f, indent=2)\n",
        "\n",
        "print(\"✅ Label encoders applied\")\n",
        "print(f\"   Unique crops  : {len(crop_mapping)}\")\n",
        "print(f\"   Unique groups : {len(group_mapping)}\")\n",
